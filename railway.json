{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "providers": ["python"]
    },
    "watchPatterns": ["app/engine/**"]
  },
  "deploy": {
    "startCommand": "cd app/engine && python -m engine.main",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
